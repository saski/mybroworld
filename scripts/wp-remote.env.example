# DonDominio production defaults confirmed in thoughts/shared/docs/woocommerce-audit.md.
# Copy to scripts/wp-remote.env and fill in the credential variables locally.

WP_REMOTE_HOST=ftp.luciastuy.com
WP_REMOTE_PATH=/public
WP_REMOTE_THEME_DIR=/public/wp-content/themes/luciastuy
WP_REMOTE_MU_PLUGIN_DIR=/public/wp-content/mu-plugins

WP_FTP_HOST=ftp.luciastuy.com
WP_REMOTE_THEME_PATH=/public/wp-content/themes/glacier
WP_LOCAL_THEME_PATH=wordpress/.tmp/glacier-audit

# Fill these locally in scripts/wp-remote.env, never commit them.
# WP_REMOTE_USER=
# WP_FTP_USER=
# WP_FTP_PASSWORD=

# Optional: automated DB dumps via mysqldump (repeatable backups).
# If these are not set, wp-backup.sh will require you to pass --db-file
# that was exported manually (phpMyAdmin).
# WP_MYSQL_HOST=
# WP_MYSQL_PORT=3306
# WP_MYSQL_DB=ddb209390
# WP_MYSQL_USER=
# WP_MYSQL_PASSWORD=
