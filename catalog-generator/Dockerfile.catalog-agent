FROM node:22-bookworm-slim

ENV CATALOG_AGENT_RUNTIME_ROOT=/tmp/mybroworld/catalog-agent \
    NODE_ENV=production \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium \
    PUPPETEER_SKIP_DOWNLOAD=true

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    chromium \
    fonts-dejavu-core \
    fonts-liberation \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY . .

RUN mkdir -p /tmp/mybroworld/catalog-agent \
  && chmod 700 /tmp/mybroworld/catalog-agent

CMD ["npm", "run", "catalog-agent:cloud-run-once"]
